    - match: '^(\s*)(`{3,})(markdown|md)(\s*)$'
      scope: markup.raw.block.markdown punctuation.definition.fenced.markdown
      captures:
        2: punctuation.definition.fenced.markdown
        3: constant.other.language-name.markdown
      embed: scope:text.html.markdown
      embed_scope: markup.raw.block.markdown text.html.markdown
      escape: '^(\s*)(`{3,})(\s*)$'
      escape_captures:
        0: markup.raw.block.markdown punctuation.definition.fenced.markdown

    # Generic fenced code blocks (with language specified but not matched above)
    - match: '^(\s*)(`{3,})([A-Za-z0-9_+-]+)(\s*)$'
      scope: markup.raw.block.markdown punctuation.definition.fenced.markdown
      captures:
        2: punctuation.definition.fenced.markdown
        3: constant.other.language-name.markdown
      push: code_block_generic

    # Generic code blocks (no language specified)
    - match: '^(\s*)(`{3,})(\s*)$'
      scope: markup.raw.block.markdown punctuation.definition.fenced.markdown
      captures:
        2: punctuation.definition.fenced.markdown
      push: code_block_plain

    # =========================================================================
    # PHASE 1 & 2: Task Management and Inline Content
    # Task title (up to ' - ') is colored, notes after are default
    # =========================================================================

    # Priority tasks [!0] through [!3] - Level 0 (no indent)
    - match: '^(\[)(![0-3])(\])(\s+)(.+?)(?= - |$)'
      captures:
        1: punctuation.definition.task.begin.scrawl
        2: keyword.control.scrawl
        3: punctuation.definition.task.end.scrawl
        5: keyword.control.scrawl
      push: task_notes

    # Priority tasks - Level 1 (4 spaces)
    - match: '^(    )(\[)(![0-3])(\])(\s+)(.+?)(?= - |$)'
      captures:
        2: punctuation.definition.task.begin.scrawl
        3: keyword.control.scrawl
        4: punctuation.definition.task.end.scrawl
        6: keyword.control.scrawl
      push: task_notes

    # Priority tasks - Level 2 (8 spaces)
    - match: '^(        )(\[)(![0-3])(\])(\s+)(.+?)(?= - |$)'
      captures:
        2: punctuation.definition.task.begin.scrawl
        3: keyword.control.scrawl
        4: punctuation.definition.task.end.scrawl
        6: keyword.control.scrawl
      push: task_notes

    # Priority tasks - Level 3+ (12+ spaces)
    - match: '^(            +)(\[)(![0-3])(\])(\s+)(.+?)(?= - |$)'
      captures:
        2: punctuation.definition.task.begin.scrawl
        3: keyword.control.scrawl
        4: punctuation.definition.task.end.scrawl
        6: keyword.control.scrawl
      push: task_notes

    # Urgent tasks [!] without priority - Level 0
    - match: '^(\[)(!)(\])(\s+)(.+?)(?= - |$)'
      captures:
        1: punctuation.definition.task.begin.scrawl
        2: keyword.control.scrawl
        3: punctuation.definition.task.end.scrawl
        5: keyword.control.scrawl
      push: task_notes

    # Urgent tasks [!] - Level 1
    - match: '^(    )(\[)(!)(\])(\s+)(.+?)(?= - |$)'
      captures:
        2: punctuation.definition.task.begin.scrawl
        3: keyword.control.scrawl
        4: punctuation.definition.task.end.scrawl
        6: keyword.control.scrawl
      push: task_notes

    # Urgent tasks [!] - Level 2
    - match: '^(        )(\[)(!)(\])(\s+)(.+?)(?= - |$)'
      captures:
        2: punctuation.definition.task.begin.scrawl
        3: keyword.control.scrawl
        4: punctuation.definition.task.end.scrawl
        6: keyword.control.scrawl
      push: task_notes

    # Urgent tasks [!] - Level 3+
    - match: '^(            +)(\[)(!)(\])(\s+)(.+?)(?= - |$)'
      captures:
        2: punctuation.definition.task.begin.scrawl
        3: keyword.control.scrawl
        4: punctuation.definition.task.end.scrawl
        6: keyword.control.scrawl
      push: task_notes

    # In-progress tasks [•] - Level 0
    - match: '^(\[)(•)(\])(\s+)(.+?)(?= - |$)'
      captures:
        1: punctuation.definition.task.begin.scrawl
        2: constant.language.scrawl
        3: punctuation.definition.task.end.scrawl
        5: constant.language.scrawl
      push: task_notes

    # In-progress tasks [•] - Level 1
    - match: '^(    )(\[)(•)(\])(\s+)(.+?)(?= - |$)'
