      push: task_notes

    # Completed tasks [x] - Level 0
    - match: '^(\[)(x)(\])(\s+)(.+?)(?= - |$)'
      captures:
        1: punctuation.definition.task.begin.scrawl
        2: string.scrawl
        3: punctuation.definition.task.end.scrawl
        5: string.scrawl
      push: task_notes

    # Completed tasks [x] - Level 1
    - match: '^(    )(\[)(x)(\])(\s+)(.+?)(?= - |$)'
