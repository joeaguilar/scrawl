    # =========================================================================
    # LIST STYLES
    # =========================================================================

    # Arrow list -> Level 0
    - match: '^(->)\s+'
      captures:
        1: markup.list.arrow.marker.level0.scrawl
      push: list_content_level0

    # Arrow list -> Level 1
    - match: '^(    )(->)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.arrow.marker.level1.scrawl
      push: list_content_level1

    # Arrow list -> Level 2
    - match: '^(        )(->)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.arrow.marker.level2.scrawl
      push: list_content_level2

    # Arrow list -> Level 3+
    - match: '^(            +)(->)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.arrow.marker.level3.scrawl
      push: list_content_level3

    # Thick arrow list => Level 0
    - match: '^(=>)\s+'
      captures:
        1: markup.list.thickarrow.marker.level0.scrawl
      push: list_content_level0

    # Thick arrow list => Level 1
    - match: '^(    )(=>)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.thickarrow.marker.level1.scrawl
      push: list_content_level1

    # Thick arrow list => Level 2
    - match: '^(        )(=>)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.thickarrow.marker.level2.scrawl
      push: list_content_level2

    # Thick arrow list => Level 3+
    - match: '^(            +)(=>)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.thickarrow.marker.level3.scrawl
      push: list_content_level3

    # Numbered list with sub-numbering (e.g., 1.1., 1.2.3.)
    - match: '^(\d+(?:\.\d+)+\.)\s+'
      captures:
        1: markup.list.numbered.marker.level0.scrawl
      push: list_content_level0

    - match: '^(    )(\d+(?:\.\d+)+\.)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.numbered.marker.level1.scrawl
      push: list_content_level1

    - match: '^(        )(\d+(?:\.\d+)+\.)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.numbered.marker.level2.scrawl
      push: list_content_level2

    - match: '^(            +)(\d+(?:\.\d+)+\.)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.numbered.marker.level3.scrawl
      push: list_content_level3

    # Simple numbered list (e.g., 1., 2., 10.)
    - match: '^(\d+\.)\s+'
      captures:
        1: markup.list.numbered.marker.level0.scrawl
      push: list_content_level0

    - match: '^(    )(\d+\.)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.numbered.marker.level1.scrawl
      push: list_content_level1

    - match: '^(        )(\d+\.)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.numbered.marker.level2.scrawl
      push: list_content_level2

    - match: '^(            +)(\d+\.)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.numbered.marker.level3.scrawl
      push: list_content_level3

    # Dash list - Level 0
    - match: '^(-)\s+'
      captures:
        1: markup.list.dash.marker.level0.scrawl
      push: list_content_level0

    # Dash list - Level 1
    - match: '^(    )(-)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.dash.marker.level1.scrawl
      push: list_content_level1

    # Dash list - Level 2
    - match: '^(        )(-)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.dash.marker.level2.scrawl
      push: list_content_level2

    # Dash list - Level 3+
    - match: '^(            +)(-)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.dash.marker.level3.scrawl
      push: list_content_level3

    # Asterisk list * Level 0
    - match: '^(\*)\s+'
      captures:
        1: markup.list.asterisk.marker.level0.scrawl
      push: list_content_level0

    # Asterisk list * Level 1
    - match: '^(    )(\*)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.asterisk.marker.level1.scrawl
      push: list_content_level1

    # Asterisk list * Level 2
    - match: '^(        )(\*)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.asterisk.marker.level2.scrawl
      push: list_content_level2

    # Asterisk list * Level 3+
    - match: '^(            +)(\*)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.asterisk.marker.level3.scrawl
      push: list_content_level3

    # Bullet list • Level 0
    - match: '^(•)\s+'
      captures:
        1: markup.list.bullet.marker.level0.scrawl
      push: list_content_level0

    # Bullet list • Level 1
    - match: '^(    )(•)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.bullet.marker.level1.scrawl
      push: list_content_level1

    # Bullet list • Level 2
    - match: '^(        )(•)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.bullet.marker.level2.scrawl
      push: list_content_level2

    # Bullet list • Level 3+
    - match: '^(            +)(•)\s+'
      captures:
        1: markup.list.indent.scrawl
        2: markup.list.bullet.marker.level3.scrawl
      push: list_content_level3

    # URL highlighting
    - match: '(https?:\/\/|www\.)[a-zA-Z0-9-]+(\.[a-zA-Z0-9-]+)+(\/[^\s\(\)\[\]]*)?'
      scope: markup.underline.link.url
      captures:
        1: markup.underline.link.protocol
        2: markup.underline.link.domain

    # Basic comment support
    - match: "//"
      scope: punctuation.definition.comment
      push: line_comment

    # Standalone inline content (Phase 2) - for non-task lines
    - include: inline_content

  # =========================================================================
  # TASK CONTENT CONTEXTS
  # =========================================================================

  # Task notes context - no meta_scope so notes appear in default color
  # This is used for the ' - notes' portion after the task title
  task_notes:
    - include: inline_content
    - match: $
      pop: true

  # =========================================================================
  # LIST CONTENT CONTEXTS
  # =========================================================================

  list_content_level0:
    - meta_scope: markup.list.content.level0.scrawl
    - include: inline_content
    - match: $
      pop: true

  list_content_level1:
    - meta_scope: markup.list.content.level1.scrawl
    - include: inline_content
    - match: $
      pop: true

  list_content_level2:
    - meta_scope: markup.list.content.level2.scrawl
    - include: inline_content
    - match: $
      pop: true

  list_content_level3:
    - meta_scope: markup.list.content.level3.scrawl
    - include: inline_content
    - match: $
      pop: true

  # =========================================================================
  # PHASE 2: INLINE CONTENT PATTERNS
  # =========================================================================

  inline_content:
    # Date token d@ with ISO format (YYYY-MM-DD with optional time)
    - match: '(d@)(\d{4}-\d{2}-\d{2})(\s+\d{1,2}:\d{2})?'
      captures:
        1: keyword.operator.date-marker.scrawl
        2: constant.other.date.scrawl
        3: constant.other.time.scrawl

    # Date token d@ with US format (MM/DD/YYYY with optional 12-hour time)
    - match: '(d@)(\d{1,2}/\d{1,2}/\d{4})(\s+\d{1,2}(:\d{2})?\s*(AM|PM|am|pm))?'
      captures:
        1: keyword.operator.date-marker.scrawl
        2: constant.other.date.scrawl
        3: constant.other.time.scrawl

    # Time estimate token e@ (hours and/or minutes)
    - match: '(e@)(\d+h)?(\d+m)?'
      captures:
        1: keyword.operator.time-marker.scrawl
        2: constant.numeric.time-estimate.hours.scrawl
        3: constant.numeric.time-estimate.minutes.scrawl

    # Progress bar [====>    ] or similar
    - match: '\[([=>\-\s]{3,20})\]'
      scope: markup.progress.bar.scrawl

    # Percentage (e.g., 50%, 100%)
    - match: '\b(\d{1,3})(%)'
      captures:
        1: constant.numeric.percentage.value.scrawl
        2: constant.numeric.percentage.sign.scrawl

    # Quick tags @word (but not d@ or e@)
    - match: '(?<![de])(@)([a-zA-Z][a-zA-Z0-9_-]*)'
      captures:
        1: punctuation.definition.tag.quick.scrawl
        2: entity.name.tag.quick.scrawl

    # Hashtags #word
    - match: '(#)([a-zA-Z][a-zA-Z0-9_-]*)'
      captures:
        1: punctuation.definition.tag.hashtag.scrawl
        2: entity.name.tag.hashtag.scrawl

  # =========================================================================
  # EXISTING CONTEXTS
  # =========================================================================

  # Code block contexts for generic or plain code blocks
  code_block_generic:
    - meta_scope: markup.raw.block.markdown
    - match: '^(\s*)(`{3,})(\s*)$'
      scope: markup.raw.block.markdown punctuation.definition.fenced.markdown
      pop: true

  code_block_plain:
    - meta_scope: markup.raw.block.markdown
    - match: '^(\s*)(`{3,})(\s*)$'
      scope: markup.raw.block.markdown punctuation.definition.fenced.markdown
      pop: true

  # Context to detect if we're in a decorative date header or regular block comment
  maybe_date_header:
    - meta_scope: comment.block.scrawl
    # Check for decorative pattern: line starting with *- (dashes)
    - match: '^\s*\*-+\s*$'
      scope: comment.block.scrawl
      set: date_header_content
    # If first content line doesn't match header pattern, treat as regular comment
    - match: '(?=\S)'
      set: block_comment
    # Empty lines are ok
    - match: '^\s*$'
    # Closing immediately means empty comment
    - match: '\*/'
      scope: comment.block.scrawl punctuation.definition.comment.block.end.scrawl
      pop: true

  # Decorative date header content
  date_header_content:
    - meta_scope: comment.block.scrawl
    - match: '\*/'
      scope: comment.block.scrawl punctuation.definition.comment.block.end.scrawl
      pop: true
    # Match date line specifically - only the date and day get highlighted
    - match: '(\d{1,2}/\d{1,2}/\d{4})\s*(\w+)?'
      captures:
        1: constant.numeric.date.scrawl
        2: constant.numeric.date.scrawl

  # Regular block comment
  block_comment:
    - meta_scope: comment.block.scrawl
    - match: '\*/'
      scope: punctuation.definition.comment.block.end.scrawl
      pop: true

  # Line comment
  line_comment:
    - meta_scope: comment.line.scrawl
    - match: $
      pop: true
