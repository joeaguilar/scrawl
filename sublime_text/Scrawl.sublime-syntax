%YAML 1.2
---
# See http://www.sublimetext.com/docs/syntax.html
name: Scrawl
file_extensions:
  - scrawl
  - note
scope: text.scrawl

variables:
  # Define language aliases and their corresponding scopes
  typescript_aliases: "typescript|ts"
  javascript_aliases: "javascript|js"
  python_aliases: "python|py"
  ruby_aliases: "ruby|rb"
  csharp_aliases: "csharp|cs|c#"
  cpp_aliases: "cpp|c\\+\\+|cxx"
  bash_aliases: "bash|sh|shell|zsh"
  html_aliases: "html|htm"
  css_aliases: "css|scss|sass|less"
  languages: "typescript|ts|javascript|js|python|py|java|c|cpp|c\\+\\+|cxx|csharp|cs|c#|html|htm|css|scss|sass|less|php|ruby|rb|go|rust|bash|sh|shell|zsh|sql|json|xml|yaml|yml|markdown|md"

contexts:
  main:
    # Decorative date header block - matches the specific format with dashes and slashes
    # Uses begin/end for multi-line matching
    - match: '/\*\s*$'
      scope: comment.block.scrawl punctuation.definition.comment.block.begin.scrawl
      push: maybe_date_header

    # Regular block comments (for inline /* ... */ on single line)
    - match: '/\*(?!\s*$)'
      scope: comment.block.scrawl punctuation.definition.comment.block.begin.scrawl
      push: block_comment

    # Section folding markers
    - match: "(##)([a-zA-Z0-9- \t]+)(##)"
      scope: markup.bold.tag entity.name.section.folding
      captures:
        1: punctuation.definition.tag.begin
        2: entity.name.tag
        3: punctuation.definition.tag.end

    # Fenced code blocks with language - completely new approach
    - match: '^(\s*)(`{3,})(typescript|ts)(\s*)$'
      scope: markup.raw.block.markdown punctuation.definition.fenced.markdown
      captures:
        2: punctuation.definition.fenced.markdown
        3: constant.other.language-name.markdown
      embed: scope:source.ts
      embed_scope: markup.raw.block.markdown source.ts
      escape: '^(\s*)(`{3,})(\s*)$'
      escape_captures:
        0: markup.raw.block.markdown punctuation.definition.fenced.markdown

    - match: '^(\s*)(`{3,})(javascript|js)(\s*)$'
      scope: markup.raw.block.markdown punctuation.definition.fenced.markdown
      captures:
        2: punctuation.definition.fenced.markdown
        3: constant.other.language-name.markdown
      embed: scope:source.js
      embed_scope: markup.raw.block.markdown source.js
      escape: '^(\s*)(`{3,})(\s*)$'
      escape_captures:
        0: markup.raw.block.markdown punctuation.definition.fenced.markdown

    - match: '^(\s*)(`{3,})(python|py)(\s*)$'
      scope: markup.raw.block.markdown punctuation.definition.fenced.markdown
      captures:
        2: punctuation.definition.fenced.markdown
        3: constant.other.language-name.markdown
      embed: scope:source.python
      embed_scope: markup.raw.block.markdown source.python
      escape: '^(\s*)(`{3,})(\s*)$'
      escape_captures:
        0: markup.raw.block.markdown punctuation.definition.fenced.markdown

    - match: '^(\s*)(`{3,})(ruby|rb)(\s*)$'
      scope: markup.raw.block.markdown punctuation.definition.fenced.markdown
      captures:
        2: punctuation.definition.fenced.markdown
