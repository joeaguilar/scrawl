##Code Block - TypeScript##

```typescript
interface Task {
  id: string;
  title: string;
  status: 'pending' | 'in_progress' | 'completed';
  priority?: number;
}

function createTask(title: string): Task {
  return {
    id: crypto.randomUUID(),
    title,
    status: 'pending'
  };
}
```

##End##

##Code Block - JavaScript##

```javascript
const tasks = [];

function addTask(title) {
  tasks.push({
    id: Date.now(),
    title,
    completed: false
  });
}

tasks.forEach(task => console.log(task.title));
```

##End##

##Code Block - Python##

```python
from dataclasses import dataclass
from typing import Optional

@dataclass
class Task:
    id: str
    title: str
    status: str = 'pending'
    priority: Optional[int] = None

def process_tasks(tasks: list[Task]) -> list[Task]:
    return [t for t in tasks if t.status != 'completed']
```

##End##

##Code Block - Bash##

```bash
#!/bin/bash

# Build and deploy script
npm install
npm run build
npm run test

if [ $? -eq 0 ]; then
    echo "Deploying..."
    npm run deploy
fi
```

##End##

##Code Block - SQL##

```sql
SELECT
    t.id,
    t.title,
    t.status,
    u.name as assignee
FROM tasks t
LEFT JOIN users u ON t.assignee_id = u.id
WHERE t.status != 'completed'
ORDER BY t.priority ASC;
```

##End##

