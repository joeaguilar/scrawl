{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Scrawl",
  "patterns": [
    { "include": "#header_block_specific" },
    { "include": "#section_folding" },
    { "include": "#fenced_code_block_typescript" },
    { "include": "#fenced_code_block_javascript" },
    { "include": "#fenced_code_block_python" },
    { "include": "#fenced_code_block_ruby" },
    { "include": "#fenced_code_block_cpp" },
    { "include": "#fenced_code_block_c" },
    { "include": "#fenced_code_block_csharp" },
    { "include": "#fenced_code_block_java" },
    { "include": "#fenced_code_block_html" },
    { "include": "#fenced_code_block_css" },
    { "include": "#fenced_code_block_scss" },
    { "include": "#fenced_code_block_sass" },
    { "include": "#fenced_code_block_less" },
    { "include": "#fenced_code_block_php" },
    { "include": "#fenced_code_block_go" },
    { "include": "#fenced_code_block_rust" },
    { "include": "#fenced_code_block_bash" },
    { "include": "#fenced_code_block_sql" },
    { "include": "#fenced_code_block_json" },
    { "include": "#fenced_code_block_xml" },
    { "include": "#fenced_code_block_yaml" },
    { "include": "#fenced_code_block_markdown" },
    { "include": "#fenced_code_block_generic" },
    { "include": "#fenced_code_block_plain" },
    { "include": "#task_priority" },
    { "include": "#task_urgent" },
    { "include": "#task_inprogress" },
    { "include": "#task_completed_check" },
    { "include": "#task_completed_x" },
    { "include": "#task_skipped" },
    { "include": "#task_onhold" },
    { "include": "#task_added" },
    { "include": "#task_question" },
    { "include": "#task_unchecked" },
    { "include": "#list_arrow" },
    { "include": "#list_thickarrow" },
    { "include": "#list_numbered_sub" },
    { "include": "#list_numbered" },
    { "include": "#list_dash" },
    { "include": "#list_asterisk" },
    { "include": "#list_bullet" },
    { "include": "#url" },
    { "include": "#line_comment" },
    { "include": "#inline_content" }
  ],
  "repository": {
    "header_block_specific": {
      "comment": "Date header block - everything grey except the date",
      "begin": "/\\*",
      "beginCaptures": {
        "0": { "name": "comment.block.scrawl" }
      },
      "end": "\\*/",
      "endCaptures": {
        "0": { "name": "comment.block.scrawl" }
      },
      "name": "comment.block.scrawl",
      "patterns": [
        {
          "comment": "Date line with day name - highlight just the date and day",
          "match": "(\\d{1,2}/\\d{1,2}/\\d{4})\\s*(\\w+)?",
          "captures": {
            "1": { "name": "constant.numeric.date.scrawl" },
            "2": { "name": "constant.numeric.date.scrawl" }
          }
        }
      ]
    },
    "section_folding": {
      "begin": "(##)",
      "beginCaptures": {
        "1": { "name": "storage.type.section.scrawl" }
      },
      "end": "(##)",
      "endCaptures": {
        "1": { "name": "storage.type.section.scrawl" }
      },
      "contentName": "keyword.control.section.scrawl",
      "patterns": [
        {
          "match": "\\([^)]*\\)",
          "name": "entity.name.function.scrawl"
        }
      ]
    },
    "url": {
      "comment": "URL pattern with bounded path length to prevent backtracking",
      "match": "(?:https?:\\/\\/|www\\.)(?:[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\\.)+[a-zA-Z]{2,}(?:\\/[^\\s\\(\\)\\[\\]]{0,2000})?",
      "name": "markup.underline.link.url"
    },
    "line_comment": {
      "match": "//.*$",
      "name": "comment.line"
    },

    "inline_content": {
      "patterns": [
        {
          "comment": "Highlight marker <<|...|>> - hot pink/invalid styling",
          "begin": "<<\\|",
          "end": "\\|>>",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.highlight.begin.scrawl" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.highlight.end.scrawl" }
          },
          "contentName": "invalid.illegal.highlight.scrawl"
        },
        {
          "comment": "Text in parenthesis - yellow (same as Added Task)",
          "match": "\\([^)]*\\)",
          "name": "entity.name.function.scrawl"
        },
        {
          "comment": "Date token d@ with ISO format - yellow (same as Added Task)",
          "match": "d@\\d{4}-\\d{2}-\\d{2}(?:\\s+\\d{1,2}:\\d{2})?",
          "name": "entity.name.function.scrawl"
        },
        {
          "comment": "Date token d@ with US format - yellow (same as Added Task)",
          "match": "d@\\d{1,2}/\\d{1,2}/\\d{4}(?:\\s+\\d{1,2}(?::\\d{2})?\\s*(?:AM|PM|am|pm))?",
          "name": "entity.name.function.scrawl"
        },
        {
          "comment": "Time estimate token e@ - yellow (same as Added Task)",
          "match": "e@(?:\\d+h)?(?:\\d+m)?",
          "name": "entity.name.function.scrawl"
        },
        {
          "comment": "Progress bar",
          "match": "\\[(?:[=>\\-\\s]{3,20})\\]",
          "name": "markup.progress.bar.scrawl"
        },
        {
          "comment": "Percentage",
          "match": "\\b\\d{1,3}%",
          "name": "constant.numeric.percentage.scrawl"
        },
        {
          "comment": "Quick tags @word (not d@ or e@)",
          "match": "(?<![de])@[a-zA-Z][a-zA-Z0-9_-]*",
          "name": "entity.name.tag.quick.scrawl"
        },
        {
          "comment": "Hashtags #word",
          "match": "#[a-zA-Z][a-zA-Z0-9_-]*",
          "name": "entity.name.tag.hashtag.scrawl"
        }
      ]
    },

    "task_priority": {
      "comment": "Priority tasks [!0-3] - all indentation levels",
      "begin": "^\\s*\\[(![0-3])\\]\\s+([^\\r\\n]+?)(?= - |$)",
      "beginCaptures": {
        "1": { "name": "keyword.control.scrawl" },
        "2": { "name": "keyword.control.scrawl" }
      },
      "end": "$",
      "patterns": [{ "include": "#inline_content" }]
    },

    "task_urgent": {
      "comment": "Urgent tasks [!] - all indentation levels",
      "begin": "^\\s*\\[(!)\\]\\s+([^\\r\\n]+?)(?= - |$)",
      "beginCaptures": {
        "1": { "name": "keyword.control.scrawl" },
        "2": { "name": "keyword.control.scrawl" }
      },
      "end": "$",
      "patterns": [{ "include": "#inline_content" }]
    },

    "task_inprogress": {
      "comment": "In-progress tasks [•] - all indentation levels",
      "begin": "^\\s*\\[(•)\\]\\s+([^\\r\\n]+?)(?= - |$)",
      "beginCaptures": {
        "1": { "name": "constant.language.scrawl" },
        "2": { "name": "constant.language.scrawl" }
      },
      "end": "$",
      "patterns": [{ "include": "#inline_content" }]
    },

    "task_completed_check": {
      "comment": "Completed tasks [√] - all indentation levels",
      "begin": "^\\s*\\[(√)\\]\\s+([^\\r\\n]+?)(?= - |$)",
      "beginCaptures": {
        "1": { "name": "string.scrawl" },
        "2": { "name": "string.scrawl" }
      },
      "end": "$",
      "patterns": [{ "include": "#inline_content" }]
    },

    "task_completed_x": {
      "comment": "Completed tasks [x] - all indentation levels",
      "begin": "^\\s*\\[(x)\\]\\s+([^\\r\\n]+?)(?= - |$)",
      "beginCaptures": {
        "1": { "name": "string.scrawl" },
        "2": { "name": "string.scrawl" }
      },
      "end": "$",
      "patterns": [{ "include": "#inline_content" }]
    },

    "task_skipped": {
      "comment": "Skipped tasks [-] - all indentation levels",
      "begin": "^\\s*\\[(-)\\]\\s+([^\\r\\n]+?)(?= - |$)",
      "beginCaptures": {
        "1": { "name": "comment.scrawl" },
        "2": { "name": "comment.scrawl" }
      },
      "end": "$",
      "patterns": [{ "include": "#inline_content" }]
    },

    "task_onhold": {
      "comment": "On-hold tasks [.] - all indentation levels",
      "begin": "^\\s*\\[(\\.)\\]\\s+([^\\r\\n]+?)(?= - |$)",
      "beginCaptures": {
        "1": { "name": "comment.scrawl" },
        "2": { "name": "comment.scrawl" }
      },
      "end": "$",
      "patterns": [{ "include": "#inline_content" }]
    },

    "task_added": {
      "comment": "Added tasks [+] - all indentation levels",
      "begin": "^\\s*\\[(\\+)\\]\\s+([^\\r\\n]+?)(?= - |$)",
      "beginCaptures": {
        "1": { "name": "entity.name.function.scrawl" },
        "2": { "name": "entity.name.function.scrawl" }
      },
      "end": "$",
      "patterns": [{ "include": "#inline_content" }]
    },

    "task_question": {
      "comment": "Question tasks [?] - all indentation levels",
      "begin": "^\\s*\\[(\\?)\\]\\s+([^\\r\\n]+?)(?= - |$)",
      "beginCaptures": {
        "1": { "name": "variable.scrawl" },
        "2": { "name": "variable.scrawl" }
      },
      "end": "$",
      "patterns": [{ "include": "#inline_content" }]
    },

    "task_unchecked": {
      "comment": "Unchecked tasks [ ] - all indentation levels",
      "begin": "^\\s*\\[( )\\]\\s+([^\\r\\n]+?)(?= - |$)",
      "beginCaptures": {
        "1": { "name": "constant.language.scrawl" },
        "2": { "name": "constant.language.scrawl" }
      },
      "end": "$",
      "patterns": [{ "include": "#inline_content" }]
    },

    "list_arrow": {
      "comment": "Arrow list -> all indentation levels",
      "begin": "^\\s*(->)\\s+",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.list.begin.scrawl" }
      },
      "end": "$",
      "patterns": [{ "include": "#inline_content" }]
    },

    "list_thickarrow": {
      "comment": "Thick arrow list => all indentation levels",
      "begin": "^\\s*(=>)\\s+",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.list.begin.scrawl" }
      },
      "end": "$",
      "patterns": [{ "include": "#inline_content" }]
    },

    "list_numbered_sub": {
      "comment": "Numbered list with sub-numbering (e.g., 1.1., 1.2.3.)",
      "begin": "^\\s*(\\d+(?:\\.\\d+)+\\.)\\s+",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.list.begin.scrawl" }
      },
      "end": "$",
      "patterns": [{ "include": "#inline_content" }]
    },

    "list_numbered": {
      "comment": "Simple numbered list (e.g., 1., 2., 10.)",
      "begin": "^\\s*(\\d+\\.)\\s+",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.list.begin.scrawl" }
      },
      "end": "$",
      "patterns": [{ "include": "#inline_content" }]
    },

    "list_dash": {
      "comment": "Dash list - all indentation levels",
      "begin": "^\\s*(-)\\s+",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.list.begin.scrawl" }
      },
      "end": "$",
      "patterns": [{ "include": "#inline_content" }]
    },

    "list_asterisk": {
      "comment": "Asterisk list * all indentation levels",
      "begin": "^\\s*(\\*)\\s+",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.list.begin.scrawl" }
      },
      "end": "$",
      "patterns": [{ "include": "#inline_content" }]
    },

    "list_bullet": {
      "comment": "Bullet list • all indentation levels",
      "begin": "^\\s*(•)\\s+",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.list.begin.scrawl" }
      },
      "end": "$",
      "patterns": [{ "include": "#inline_content" }]
    },

    "fenced_code_block_typescript": {
      "begin": "^\\s*(`{3,})(typescript|ts)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.fenced.code" },
        "2": { "name": "entity.name.tag.language" }
      },
      "end": "^\\s*`{3,}\\s*$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.fenced.code" }
      },
      "contentName": "source.ts",
      "patterns": [{ "include": "source.ts" }]
    },
    "fenced_code_block_javascript": {
