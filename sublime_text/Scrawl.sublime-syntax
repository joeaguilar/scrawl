        4: punctuation.definition.task.end.scrawl
        6: constant.language.scrawl
      push: task_notes

    # Completed tasks [√] - Level 0
    - match: '^(\[)(√)(\])(\s+)(.+?)(?= - |$)'
      captures:
        1: punctuation.definition.task.begin.scrawl
        2: string.scrawl
        3: punctuation.definition.task.end.scrawl
        5: string.scrawl
      push: task_notes

    # Completed tasks [√] - Level 1
