  "repository": {
    "header_block_specific": {
      "match": "/\\*\\s*\\n\\s*\\*-*\\s*\\n\\s*\\*\\s*/+\\s*\\n\\s*\\*\\s*\\d+/\\d+/\\d+\\s*\\w+\\s*\\n\\s*\\*\\s*/+\\s*\\n\\s*\\*-*\\s*\\n\\s*\\*/",
      "name": "punctuation.definition.comment.block"
    },
    "header_block_simple": {
      "begin": "/\\*",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.block.begin" }
      },
      "end": "\\*/",
      "endCaptures": {
        "0": { "name": "punctuation.definition.comment.block.end" }
      },
      "contentName": "comment.block markup.heading.note-header"
    },
    "section_folding": {
      "match": "(##)([a-zA-Z0-9- \\t]+)(##)",
      "name": "markup.bold.tag entity.name.section.folding",
      "captures": {
        "1": { "name": "punctuation.definition.tag.begin" },
        "2": { "name": "entity.name.tag" },
        "3": { "name": "punctuation.definition.tag.end" }
      }
    },
    "url": {
      "match": "(https?:\\/\\/|www\\.)[a-zA-Z0-9-]+(\\.[a-zA-Z0-9-]+)+(\\/[^\\s\\(\\)\\[\\]]*)?",
      "name": "markup.underline.link.url",
      "captures": {
        "1": { "name": "markup.underline.link.protocol" },
        "2": { "name": "markup.underline.link.domain" }
      }
    },
    "line_comment": {
      "match": "//.*$",
      "name": "comment.line"
    },

    "inline_content": {
      "patterns": [
        {
          "comment": "Date token d@ with ISO format",
          "match": "(d@)(\\d{4}-\\d{2}-\\d{2})(\\s+\\d{1,2}:\\d{2})?",
          "captures": {
            "1": { "name": "keyword.operator.date-marker.scrawl" },
            "2": { "name": "constant.other.date.scrawl" },
            "3": { "name": "constant.other.time.scrawl" }
          }
        },
        {
          "comment": "Date token d@ with US format",
          "match": "(d@)(\\d{1,2}/\\d{1,2}/\\d{4})(\\s+\\d{1,2}(:\\d{2})?\\s*(AM|PM|am|pm))?",
          "captures": {
            "1": { "name": "keyword.operator.date-marker.scrawl" },
            "2": { "name": "constant.other.date.scrawl" },
            "3": { "name": "constant.other.time.scrawl" }
          }
        },
        {
          "comment": "Time estimate token e@",
          "match": "(e@)(\\d+h)?(\\d+m)?",
          "captures": {
            "1": { "name": "keyword.operator.time-marker.scrawl" },
            "2": { "name": "constant.numeric.time-estimate.hours.scrawl" },
            "3": { "name": "constant.numeric.time-estimate.minutes.scrawl" }
          }
        },
        {
          "comment": "Progress bar",
          "match": "\\[([=>\\-\\s]{3,20})\\]",
          "name": "markup.progress.bar.scrawl"
        },
        {
          "comment": "Percentage",
          "match": "\\b(\\d{1,3})(%)",
          "captures": {
            "1": { "name": "constant.numeric.percentage.value.scrawl" },
            "2": { "name": "constant.numeric.percentage.sign.scrawl" }
          }
        },
        {
          "comment": "Quick tags @word (not d@ or e@)",
          "match": "(?<![de])(@)([a-zA-Z][a-zA-Z0-9_-]*)",
          "captures": {
            "1": { "name": "punctuation.definition.tag.quick.scrawl" },
            "2": { "name": "entity.name.tag.quick.scrawl" }
          }
        },
        {
          "comment": "Hashtags #word",
          "match": "(#)([a-zA-Z][a-zA-Z0-9_-]*)",
          "captures": {
            "1": { "name": "punctuation.definition.tag.hashtag.scrawl" },
            "2": { "name": "entity.name.tag.hashtag.scrawl" }
          }
        }
      ]
    },

    "task_priority_level0": {
