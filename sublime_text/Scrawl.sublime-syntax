    # On-hold tasks [.] - Level 3+
    - match: '^(            +)(\[)(\.)(\])(\s+)(.+?)(?= - |$)'
      captures:
        2: punctuation.definition.task.begin.scrawl
        3: comment.scrawl
        4: punctuation.definition.task.end.scrawl
        6: comment.scrawl
      push: task_notes

    # Added tasks [+] - Level 0
    - match: '^(\[)(\+)(\])(\s+)(.+?)(?= - |$)'
      captures:
        1: punctuation.definition.task.begin.scrawl
        2: entity.name.function.scrawl
        3: punctuation.definition.task.end.scrawl
        5: entity.name.function.scrawl
      push: task_notes

    # Added tasks [+] - Level 1
    - match: '^(    )(\[)(\+)(\])(\s+)(.+?)(?= - |$)'
      captures:
        2: punctuation.definition.task.begin.scrawl
        3: entity.name.function.scrawl
        4: punctuation.definition.task.end.scrawl
        6: entity.name.function.scrawl
      push: task_notes

    # Added tasks [+] - Level 2
    - match: '^(        )(\[)(\+)(\])(\s+)(.+?)(?= - |$)'
      captures:
        2: punctuation.definition.task.begin.scrawl
        3: entity.name.function.scrawl
        4: punctuation.definition.task.end.scrawl
        6: entity.name.function.scrawl
      push: task_notes

    # Added tasks [+] - Level 3+
    - match: '^(            +)(\[)(\+)(\])(\s+)(.+?)(?= - |$)'
      captures:
        2: punctuation.definition.task.begin.scrawl
        3: entity.name.function.scrawl
        4: punctuation.definition.task.end.scrawl
        6: entity.name.function.scrawl
