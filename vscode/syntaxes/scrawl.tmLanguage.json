{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Scrawl",
  "patterns": [
    {
      "include": "#header_block_specific"
    },
    {
      "include": "#header_block_simple"
    },
    {
      "include": "#section_folding"
    },
    {
      "include": "#url"
    },
    {
      "include": "#fenced_code_block_typescript"
    },
    {
      "include": "#fenced_code_block_javascript"
    },
    {
      "include": "#fenced_code_block_python"
    },
    {
      "include": "#fenced_code_block_ruby"
    },
    {
      "include": "#fenced_code_block_cpp"
    },
    {
      "include": "#fenced_code_block_c"
    },
    {
