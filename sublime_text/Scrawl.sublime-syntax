    # Unchecked tasks [ ] - Level 0
    - match: '^(\[)( )(\])(\s+)(.+?)(?= - |$)'
      captures:
        1: punctuation.definition.task.begin.scrawl
        2: constant.language.scrawl
        3: punctuation.definition.task.end.scrawl
        5: constant.language.scrawl
