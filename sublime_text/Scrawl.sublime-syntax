        3: string.scrawl
        4: punctuation.definition.task.end.scrawl
        6: string.scrawl
      push: task_notes

    # Skipped tasks [-] - Level 0
    - match: '^(\[)(-)(\])(\s+)(.+?)(?= - |$)'
      captures:
        1: punctuation.definition.task.begin.scrawl
        2: comment.scrawl
        3: punctuation.definition.task.end.scrawl
        5: comment.scrawl
      push: task_notes

    # Skipped tasks [-] - Level 1
    - match: '^(    )(\[)(-)(\])(\s+)(.+?)(?= - |$)'
      captures:
        2: punctuation.definition.task.begin.scrawl
        3: comment.scrawl
