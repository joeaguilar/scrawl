  "repository": {
    "header_block_specific": {
      "match": "/\\*\\s*\\n\\s*\\*-*\\s*\\n\\s*\\*\\s*/+\\s*\\n\\s*\\*\\s*\\d+/\\d+/\\d+\\s*\\w+\\s*\\n\\s*\\*\\s*/+\\s*\\n\\s*\\*-*\\s*\\n\\s*\\*/",
      "name": "punctuation.definition.comment.block"
    },
    "header_block_simple": {
      "begin": "/\\*",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.comment.block.begin"
        }
      },
      "end": "\\*/",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.comment.block.end"
        }
      },
      "contentName": "comment.block markup.heading.note-header"
    },
    "section_folding": {
      "match": "(##)([a-zA-Z0-9- \\t]+)(##)",
      "name": "markup.bold.tag entity.name.section.folding",
      "captures": {
        "1": {
          "name": "punctuation.definition.tag.begin"
        },
        "2": {
          "name": "entity.name.tag"
        },
        "3": {
          "name": "punctuation.definition.tag.end"
        }
      }
    },
    "url": {
      "match": "(https?:\\/\\/|www\\.)[a-zA-Z0-9-]+(\\.[a-zA-Z0-9-]+)+(\\/[^\\s\\(\\)\\[\\]]*)?",
      "name": "markup.underline.link.url",
      "captures": {
        "1": {
          "name": "markup.underline.link.protocol"
        },
        "2": {
          "name": "markup.underline.link.domain"
        }
      }
    },
    "fenced_code_block_typescript": {
      "begin": "^(\\s*)(`{3,})(typescript|ts)(\\s*)$",
      "beginCaptures": {
        "2": {
          "name": "punctuation.definition.fenced.code"
        },
        "3": {
          "name": "entity.name.tag.language"
        }
      },
      "end": "^(\\s*)(`{3,})(\\s*)$",
      "endCaptures": {
        "2": {
          "name": "punctuation.definition.fenced.code"
        }
      },
      "contentName": "source.ts",
      "patterns": [
        {
          "include": "source.ts"
        }
      ]
    },
    "fenced_code_block_javascript": {
      "begin": "^(\\s*)(`{3,})(javascript|js)(\\s*)$",
