{
    "name": "Scrawl Color Scheme",
    "author":"bluesourboy",
    "variables": {},
    "globals": {
        "background": "#272822",
        "foreground": "#F8F8F2",
        "caret": "#F8F8F2"
    },
    "rules": [
        {
            "name": "Note Header",
            "scope": "markup.heading.note-header",
            "foreground": "#66D9EF",
            "font_style": "bold"
        },
        {
            "name": "Tag",
            "scope": "entity.name.tag",
            "foreground": "#A6E22E",
            "font_style": "bold"
        },
        {
            "name": "Tag Wrapper",
            "scope": "markup.bold.tag",
            "foreground": "#75715E"
        },
        {
            "name": "URL",
            "scope": "markup.underline.link.url",
            "foreground": "#66D9EF",
            "font_style": "underline",
            "background": "#272822",  // Keep same as document background
            "border": "thin solid #66D9EF" // Creates underline effect
        },
        ,
        {
            "name": "Code Block",
            "scope": "markup.raw.codeblock",
            "background": "#232521",
            "foreground": "#E6DB74"
        },
        {
            "name": "Code Block Language",
            "scope": "entity.name.function.language",
            "foreground": "#FD971F",
            "font_style": "italic"
        },
               {
            "name": "Code Block Background",
            "scope": "markup.raw.block",
            "background": "#1E1F1C"
        },
        {
            "name": "Code Block Language",
            "scope": "entity.name.function.language",
            "foreground": "#FD971F",
            "font_style": "italic"
        },
        {
            "name": "Code Block Markers",
            "scope": "punctuation.definition.codeblock",
            "foreground": "#75715E"
        }
    ]
}